package service

import (
	"context"
	"fmt"

	"{{ .Module }}/internal/orders/domain"
)

// Repository is the persistence contract for the orders module.
type Repository interface {
	FindByID(ctx context.Context, id string) (*domain.Order, error)
	Save(ctx context.Context, order *domain.Order) error
}

// OrderService orchestrates order operations within the module boundary.
type OrderService struct {
	repo Repository
}

// NewOrderService creates an OrderService with the given repository.
func NewOrderService(repo Repository) *OrderService {
	return &OrderService{repo: repo}
}

// GetOrder retrieves an order by ID.
func (s *OrderService) GetOrder(ctx context.Context, id string) (*domain.Order, error) {
	o, err := s.repo.FindByID(ctx, id)
	if err != nil {
		return nil, fmt.Errorf("get order: %w", err)
	}
	return o, nil
}
