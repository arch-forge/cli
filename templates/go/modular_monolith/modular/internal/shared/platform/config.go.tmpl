package platform

import "os"

// Config holds application-wide configuration shared across modules.
type Config struct {
	Port     string
	LogLevel string
}

// LoadConfig reads configuration from environment variables.
func LoadConfig() Config {
	port := os.Getenv("PORT")
	if port == "" {
		port = "8080"
	}
	return Config{Port: port, LogLevel: os.Getenv("LOG_LEVEL")}
}
