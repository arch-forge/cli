// NewGet{{ pascalCase .DomainName }}UseCase constructs the use case.
func NewGet{{ pascalCase .DomainName }}UseCase(repo domain.{{ pascalCase .DomainName }}Repository) *Get{{ pascalCase .DomainName }}UseCase {
