package handler

import (
	"encoding/json"
	"net/http"

	"{{ .Module }}/{{ .Paths.App }}"
)

// {{ pascalCase .DomainName }}Handler handles HTTP requests for the {{ .DomainName }} module.
type {{ pascalCase .DomainName }}Handler struct {
	svc *service.{{ pascalCase .DomainName }}Service
}

// New{{ pascalCase .DomainName }}Handler constructs the handler.
func New{{ pascalCase .DomainName }}Handler(svc *service.{{ pascalCase .DomainName }}Service) *{{ pascalCase .DomainName }}Handler {
	return &{{ pascalCase .DomainName }}Handler{svc: svc}
}

// RegisterRoutes registers routes on the mux.
func (h *{{ pascalCase .DomainName }}Handler) RegisterRoutes(mux *http.ServeMux) {
	mux.HandleFunc("GET /{{ .DomainName }}s/{id}", h.getOne)
}

func (h *{{ pascalCase .DomainName }}Handler) getOne(w http.ResponseWriter, r *http.Request) {
	id := r.PathValue("id")
	e, err := h.svc.Get(r.Context(), id)
	if err != nil {
		http.Error(w, err.Error(), http.StatusNotFound)
		return
	}
	w.Header().Set("Content-Type", "application/json")
	json.NewEncoder(w).Encode(e)
}
