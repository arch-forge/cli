variable "region" {
  description = "AWS region"
  type        = string
  default     = "{{ index .Options "region" | default "us-east-1" }}"
}

variable "image_uri" {
  description = "Container image URI"
  type        = string
}

variable "environment" {
  description = "Deployment environment (dev, staging, prod)"
  type        = string
  default     = "dev"
}
