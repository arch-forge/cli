package domain

// User is the core domain entity representing a system user.
type User struct {
	ID    string
	Name  string
	Email string
}

// Validate returns an error if the User is in an invalid state.
func (u *User) Validate() error {
	if u.Name == "" {
		return ErrInvalidUser
	}
	if u.Email == "" {
		return ErrInvalidUser
	}
	return nil
}
