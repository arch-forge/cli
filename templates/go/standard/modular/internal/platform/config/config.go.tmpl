package config

import "os"

// Config holds application-wide configuration.
type Config struct {
	Port     string
	LogLevel string
}

// Load reads configuration from environment variables with sensible defaults.
func Load() Config {
	port := os.Getenv("PORT")
	if port == "" {
		port = "8080"
	}
	logLevel := os.Getenv("LOG_LEVEL")
	if logLevel == "" {
		logLevel = "info"
	}
	return Config{Port: port, LogLevel: logLevel}
}
